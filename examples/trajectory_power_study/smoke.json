{
  "intersim": {
    "seed": 1,
    "n_sample": 30,
    "cluster_sample_prop": [0.5, 0.5]
  },
  "generator": {
    "seed": 2,
    "trajectory_mode": "magnitude",
    "group_effect_size": 0.0,
    "group_ratio": 0.5,
    "prop_affected_features": 0.1
  },
  "evaluation": {
    "integration_method": "concat",
    "permutations": 49,
    "n_jobs": 1,
    "seed": 3
  },
  "trajectory_modes": ["magnitude", "orientation", "shape", "translation"],
  "effect_sizes": [0.0, 0.25, 0.5, 1.0],
  "axes": {},
  "n_replicates": 8,
  "base_seed": 100,
  "alpha": 0.05,
  "acceptance": {
    "type_i": [
      {"alpha": 0.05, "se_tolerance": 2.0}
    ],
    "power": [
      {"trajectory_mode": "magnitude", "statistic": "delta", "min_power_at_top": 0.5},
      {"trajectory_mode": "orientation", "statistic": "angle", "min_power_at_top": 0.5},
      {"trajectory_mode": "shape", "statistic": "shape", "min_power_at_top": 0.5}
    ],
    "specificity": [
      {"trajectory_mode": "translation", "statistic": "delta", "alpha": 0.05},
      {"trajectory_mode": "translation", "statistic": "angle", "alpha": 0.05},
      {"trajectory_mode": "translation", "statistic": "shape", "alpha": 0.05}
    ]
  },
  "metadata": {
    "name": "trajectory-power-study-smoke",
    "intent": "Tiny end-to-end smoke for the study pipeline; not paper-grade."
  }
}
